# Database
DB_URI=mysql+aiomysql://username:password@localhost:3306/ainame?charset=utf8mb4
POSTGRES_MEMORY_DB_URI=postgresql://username:password@localhost:5432/ainame

# LangGraph checkpoint memory (PostgreSQL, separate from the MySQL business DB_URI)
LANGGRAPH_CHECKPOINT_DB_URI=postgresql://postgres:123456@localhost:5432/ainame
LANGGRAPH_CHECKPOINT_CONNECT_TIMEOUT=10
LANGGRAPH_CHECKPOINT_FALLBACK_TO_MEMORY=true

# Redis
REDIS_URL=redis://127.0.0.1:6379

# RabbitMQ
RABBITMQ_URL=amqp://username:password@127.0.0.1:5672/

# Mail
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_auth_code
MAIL_FROM=your_email@qq.com
MAIL_PORT=587
MAIL_SERVER=smtp.qq.com
MAIL_FROM_NAME=ainameapp
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRES_DAYS=1
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
LLM_TIMEOUT_SECONDS=30
THIRD_PARTY_TIMEOUT_SECONDS=10
TASK_MAX_RETRIES=3
TASK_CIRCUIT_FAILURE_THRESHOLD=5
TASK_CIRCUIT_RESET_SECONDS=60
ALIPAY_SANDBOX_CALLBACK_SECRET=replace-with-callback-secret

# AI
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

# Observability
LOG_LEVEL=INFO
REQUEST_SLOW_MS=1000
